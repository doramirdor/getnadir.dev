# Cloudflare Pages headers — ported 1:1 from ../../netlify.toml
# Pages serves this file from the dist/ root. Keep in sync with netlify.toml
# until Netlify is fully decommissioned.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://*.posthog.com https://*.i.posthog.com https://connect.facebook.net https://www.facebook.com https://snap.licdn.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.github.com https://*.posthog.com https://*.i.posthog.com https://api.getnadir.com https://www.facebook.com https://connect.facebook.net https://api.facebook.com https://graph.facebook.com https://px.ads.linkedin.com https://snap.licdn.com; frame-src https://*.tella.tv https://www.facebook.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'

# Vite content-hashed assets — safe to cache for a year (immutable filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# ── Required ──────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_PROJECT_ID=your-project-id

# At least ONE provider key required for LLM routing
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AI...

# ── Hosted mode (Bedrock) ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# ── Stripe (required for billing) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_BASE=price_...    # Stripe Price ID for $9/mo base plan

# ── Production ───────────────────────────────────────────────────────
# ENVIRONMENT=production
# DEBUG=False
# CORS_ORIGINS=https://getnadir.com,https://app.getnadir.com

# ── Optional ─────────────────────────────────────────────────────────
# COMPLEXITY_ANALYZER_TYPE=binary
# RATE_LIMIT_PER_MINUTE=60
# RATE_LIMIT_INSTANCE_DIVISOR=1
# ENABLE_RESPONSE_HEALING=True
# HEALTH_MONITOR_WINDOW_SIZE=100
